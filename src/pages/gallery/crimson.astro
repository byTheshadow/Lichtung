---
import BaseLayout from '../../layouts/BaseLayout.astro';
import images from '../../data/crimson.json';
---

<BaseLayout title="Crimson · 绯" accent="#ff2a2a">
  <section class="page-hero">
    <p class="eyebrow">Color · 01</p>
    <h1>绯 Crimson</h1>
    <p class="desc">深红、暗火、灰烬里未熄的一点。</p>
  </section>

  <div class="gallery">
    {images.map((img, i) => (
      <figure class="tile" style={`--i:${i}`}>
        <img
          src={img.src}
          alt={img.alt ?? ''}
          loading="lazy"
          decoding="async"
        />
        {img.caption && <figcaption>{img.caption}</figcaption>}
      </figure>
    ))}
  </div>
</BaseLayout>

<style>
  .page-hero { margin-bottom: 40px; }
  .eyebrow { color: var(--text-sub); font-size: 12px; letter-spacing: 3px; margin-bottom: 10px; }
  .page-hero h1 {
    font-family: var(--font-serif);
    font-size: 48px;
    letter-spacing: 3px;
    margin-bottom: 8px;
  }
  .desc { color: var(--text-sub); font-size: 14px; }

  .gallery {
    columns: 3;
    column-gap: 16px;
  }
  @media (max-width: 1200px) { .gallery { columns: 2; } }

  .tile {
    break-inside: avoid;
    margin-bottom: 16px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel-bg);
    border: 1px solid var(--border-color);
    content-visibility: auto;              /* 关键：屏外跳过渲染 */
    contain-intrinsic-size: 400px;
    transition: transform 0.3s, border-color 0.3s;
  }
  .tile:hover {
    transform: translateY(-3px);
    border-color: var(--accent-soft);
  }
  .tile img {
    width: 100%;
    display: block;
    height: auto;
  }
  figcaption {
    padding: 10px 14px;
    font-size: 12px;
    color: var(--text-sub);
  }
</style>
